# Supabase — obtener en https://supabase.com/dashboard/project/_/settings/api
# Estas vars se baked en build time — deben estar también en GitHub Secrets
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key-aqui

# Supabase Service Role — solo server-side, nunca exponer en el cliente
# Debe estar en GitHub Secrets (no en wrangler.toml)
SUPABASE_SERVICE_ROLE_KEY=tu-service-role-key-aqui
